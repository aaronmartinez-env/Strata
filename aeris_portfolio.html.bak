<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AERIS — Atmospheric Interpretation System · Valencia</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,300;0,400;0,700;1,300&family=Cormorant+Garamond:ital,wght@0,300;1,300;1,400;1,600&family=IBM+Plex+Sans:wght@300;400&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --void:#04060a; --deep:#070c12; --surface:#0c1420;
  --glass:rgba(8,16,28,0.72); --glass2:rgba(10,18,32,0.88);
  --rim:rgba(80,160,240,0.10); --rim2:rgba(80,160,240,0.22);
  --fog:rgba(255,255,255,0.04);
  --text:#c8d8e8; --muted:#3a5060; --dim:#1a2a38;
  --cyan:#00d4ff; --teal:#00b896; --amber:#ff9a00;
  --red:#ff4455; --green:#39d98a; --purple:#8b6fff;
  --mono:'IBM Plex Mono',monospace;
  --serif:'Cormorant Garamond',Georgia,serif;
  --sans:'IBM Plex Sans',sans-serif;
}
html{background:var(--void);color:var(--text);font-family:var(--sans);font-weight:300;font-size:17px;line-height:1.75;scroll-behavior:smooth;}
body{overflow-x:hidden;}
#atmos-canvas{position:fixed;inset:0;z-index:0;pointer-events:none;}
body::before{content:'';position:fixed;inset:0;z-index:1;pointer-events:none;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");opacity:0.45;}
.wrap{position:relative;z-index:2;max-width:1200px;margin:0 auto;padding:0 3.5rem;}

/* NAV */
.nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:1rem 2.5rem;display:flex;justify-content:space-between;align-items:center;background:linear-gradient(to bottom,rgba(4,6,10,0.96) 0%,transparent 100%);}
.nav-logo{font-family:var(--mono);font-size:0.72rem;font-weight:700;letter-spacing:0.22em;color:var(--cyan);text-transform:uppercase;}
.nav-logo span{color:var(--muted);font-weight:300;}
.nav-links{display:flex;gap:1.75rem;}
.nav-links a{font-family:var(--mono);font-size:0.58rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:color 0.2s;}
.nav-links a:hover{color:var(--cyan);}

/* HERO */
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 0 5rem;}
.hero-status{display:flex;align-items:center;gap:0.75rem;margin-bottom:2.5rem;}
.sdot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 2.4s ease-in-out infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:0.35;transform:scale(0.75);}}
.stext{font-family:var(--mono);font-size:0.6rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--green);}
.hero-eyebrow{font-family:var(--mono);font-size:0.58rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--muted);margin-bottom:1.5rem;}
.hero-title{font-family:var(--serif);font-style:italic;font-weight:300;font-size:clamp(3rem,5.8vw,5.5rem);line-height:1.08;color:var(--text);margin-bottom:1.5rem;max-width:900px;}
.hero-title em{font-style:normal;color:var(--cyan);}
.hero-sub{font-size:1.05rem;color:rgba(200,216,232,0.72);max-width:680px;line-height:1.88;margin-bottom:3rem;font-weight:300;}
.ticker-wrap{display:flex;align-items:center;gap:0.9rem;margin-bottom:3.5rem;}
.ticker-pre{font-family:var(--mono);font-size:0.58rem;letter-spacing:0.14em;color:var(--cyan);text-transform:uppercase;white-space:nowrap;}
.ticker-el{font-family:var(--mono);font-size:0.7rem;color:rgba(200,216,232,0.65);}
.tcursor{display:inline-block;width:5px;height:11px;background:var(--cyan);animation:blink 1.1s step-end infinite;vertical-align:middle;margin-left:2px;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
.hero-stats{display:flex;border:1px solid var(--rim);border-radius:4px;overflow:hidden;backdrop-filter:blur(20px);background:var(--glass);width:fit-content;}
.hs{padding:1rem 1.65rem;border-right:1px solid var(--rim);}
.hs:last-child{border-right:none;}
.hs-val{font-family:var(--mono);font-size:1.45rem;font-weight:700;line-height:1;display:block;}
.hs-label{font-family:var(--mono);font-size:0.5rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);margin-top:4px;display:block;}

/* REVEAL */
.reveal{opacity:0;transform:translateY(18px);transition:opacity 0.65s ease,transform 0.65s ease;}
.reveal.visible{opacity:1;transform:translateY(0);}

/* CHAPTERS */
.chapter{padding:6rem 0;border-top:1px solid var(--fog);scroll-margin-top:80px;}
.ch-head{display:grid;grid-template-columns:44px 1fr;gap:2.5rem;align-items:start;margin-bottom:3.25rem;}
.ch-num{font-family:var(--mono);font-size:0.53rem;letter-spacing:0.15em;color:var(--muted);text-transform:uppercase;padding-top:7px;}
.ch-title{font-family:var(--serif);font-style:italic;font-weight:300;font-size:clamp(2rem,3.5vw,3rem);color:var(--text);line-height:1.18;}
.ch-title em{font-style:normal;color:var(--cyan);}
.ch-sub{display:block;font-family:var(--mono);font-style:normal;font-size:0.58rem;letter-spacing:0.16em;color:var(--muted);text-transform:uppercase;margin-top:0.6rem;font-weight:300;}

/* PROSE */
.prose{max-width:820px;margin:0 0 2.5rem;}
.prose p{color:rgba(200,216,232,0.88);font-size:1rem;line-height:1.9;margin-bottom:1.35rem;font-weight:300;}
.prose strong{color:#ffffff;font-weight:600;}
.prose em{color:var(--cyan);font-style:normal;}

/* GLASS PANELS */
.gp{background:var(--glass);border:1px solid var(--rim);border-radius:5px;backdrop-filter:blur(22px);padding:1.6rem;margin:1.5rem 0;position:relative;overflow:hidden;}
.gp::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,var(--rim2),transparent);}
.gp.amber{border-color:rgba(255,154,0,0.2);background:rgba(255,100,0,0.04);}
.gp.amber::before{background:linear-gradient(to right,transparent,rgba(255,154,0,0.38),transparent);}
.gp.red{border-color:rgba(255,68,85,0.2);background:rgba(255,68,85,0.04);}
.gp.red::before{background:linear-gradient(to right,transparent,rgba(255,68,85,0.35),transparent);}
.gp.green{border-color:rgba(57,217,138,0.18);background:rgba(57,217,138,0.04);}
.gp.green::before{background:linear-gradient(to right,transparent,rgba(57,217,138,0.3),transparent);}
.gp.calima{border-color:rgba(255,154,0,0.22);background:linear-gradient(135deg,rgba(255,154,0,0.05),rgba(255,68,85,0.03));}
.gp-label{font-family:var(--mono);font-size:0.53rem;letter-spacing:0.17em;text-transform:uppercase;color:var(--cyan);margin-bottom:0.55rem;}
.gp-label.amber{color:var(--amber);}
.gp-label.red{color:var(--red);}
.gp-label.green{color:var(--green);}
.gp-label.calima{color:var(--amber);}
.gp p{font-size:0.97rem;color:rgba(200,216,232,0.92);line-height:1.78;margin:0;}
.gp strong{color:#ffffff;font-weight:600;}

/* METRIC ROW */
.mrow{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:1px;background:var(--rim);border:1px solid var(--rim);border-radius:5px;overflow:hidden;margin:2rem 0;}
.mc{background:var(--glass2);padding:1.15rem 1.3rem;}
.mc-label{font-family:var(--mono);font-size:0.58rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);margin-bottom:0.35rem;}
.mc-val{font-family:var(--mono);font-size:1.5rem;font-weight:700;line-height:1;}
.mc-sub{font-family:var(--mono);font-size:0.62rem;color:var(--muted);margin-top:0.25rem;}

/* MAP */
.map-wrap{position:relative;border-radius:5px;overflow:hidden;border:1px solid var(--rim);margin:1.5rem 0;}
#map{height:460px;}
.map-hud{position:absolute;top:1rem;left:1rem;z-index:500;background:var(--glass2);border:1px solid var(--rim);backdrop-filter:blur(16px);border-radius:4px;padding:0.7rem 0.9rem;}
.map-hud-label{font-family:var(--mono);font-size:0.52rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--muted);margin-bottom:0.45rem;}
.ml-row{display:flex;align-items:center;gap:5px;margin-bottom:3px;}
.ml-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.ml-row span{font-family:var(--mono);font-size:0.56rem;color:var(--muted);}

/* STATION GRID */
.sgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(215px,1fr));gap:1px;background:var(--rim);border:1px solid var(--rim);border-radius:5px;overflow:hidden;margin:1.5rem 0;}
.sc{background:var(--glass2);padding:1rem 1.15rem;transition:background 0.2s;}
.sc:hover{background:rgba(0,212,255,0.035);}
.sc-name{font-family:var(--mono);font-size:0.7rem;font-weight:700;color:var(--cyan);margin-bottom:0.7rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;letter-spacing:0.04em;}
.br{display:flex;align-items:center;gap:5px;margin-bottom:3px;}
.bl{font-family:var(--mono);font-size:0.5rem;color:var(--muted);width:26px;text-align:right;text-transform:uppercase;}
.bt{flex:1;height:3px;background:rgba(255,255,255,0.05);border-radius:2px;overflow:hidden;}
.bf{height:100%;border-radius:2px;}
.bv{font-family:var(--mono);font-size:0.54rem;color:var(--muted);width:22px;}
.sc-foot{display:flex;justify-content:space-between;margin-top:0.65rem;padding-top:0.65rem;border-top:1px solid rgba(255,255,255,0.04);}
.ss span:first-child{font-family:var(--mono);font-size:0.76rem;font-weight:700;display:block;}
.ss span:last-child{font-family:var(--mono);font-size:0.47rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;}

/* CHARTS */
.cg{background:var(--glass);border:1px solid var(--rim);border-radius:5px;padding:1.4rem;margin:1.5rem 0;position:relative;}
.cg::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,var(--rim2),transparent);}
.cg-label{font-family:var(--mono);font-size:0.53rem;letter-spacing:0.13em;text-transform:uppercase;color:var(--muted);margin-bottom:0.85rem;}
.cg-legend{display:flex;gap:1.4rem;flex-wrap:wrap;margin-bottom:0.8rem;}
.cpill{display:flex;align-items:center;gap:5px;font-family:var(--mono);font-size:0.58rem;color:rgba(200,216,232,0.45);}
.cpill-line{width:15px;height:1.5px;border-radius:1px;}
.cpill-dash{width:15px;height:0;border-top:1.5px dashed;}
.c2col{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin:1.5rem 0;}
@media(max-width:660px){.c2col{grid-template-columns:1fr;}}

/* CORR TABLE */
.ctbl{width:100%;border-collapse:collapse;font-family:var(--mono);font-size:0.67rem;}
.ctbl th{text-align:left;padding:0.38rem 0.6rem;font-size:0.5rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid rgba(255,255,255,0.05);font-weight:300;}
.ctbl td{padding:0.45rem 0.6rem;border-bottom:1px solid rgba(255,255,255,0.03);color:rgba(200,216,232,0.55);}
.ctbl tr:last-child td{border:none;}

/* DATA NOTE */
.dnote{font-family:var(--mono);font-size:0.65rem;color:rgba(200,216,232,0.62);background:var(--fog);border:1px solid rgba(255,255,255,0.06);border-radius:4px;padding:0.85rem 1.1rem;line-height:1.95;margin:1.2rem 0;}
.dnote strong{color:rgba(200,216,232,0.75);font-weight:600;}

/* CONCLUSION GRID */
.cgrid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--rim);border:1px solid var(--rim);border-radius:5px;overflow:hidden;margin:2rem 0;}
@media(max-width:580px){.cgrid{grid-template-columns:1fr;}}
.cb{background:var(--glass2);padding:1.4rem;}
.cb-label{font-family:var(--mono);font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);margin-bottom:0.65rem;}
.cb p{font-size:0.95rem;color:rgba(200,216,232,0.82);line-height:1.78;font-weight:300;}
.cb strong{color:#ffffff;font-weight:600;}

/* CITE GRID */
.cite-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin:1.5rem 0;}
@media(max-width:660px){.cite-grid{grid-template-columns:1fr;}}
.cite-block{background:var(--glass);border:1px solid var(--rim);border-radius:5px;padding:1.3rem;}
.cite-block-label{font-family:var(--mono);font-size:0.51rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);margin-bottom:0.8rem;padding-bottom:0.55rem;border-bottom:1px solid rgba(255,255,255,0.04);}
.cite-row{display:flex;flex-direction:column;gap:0.15rem;margin-bottom:0.7rem;}
.cite-key{font-family:var(--mono);font-size:0.6rem;color:rgba(200,216,232,0.5);text-transform:uppercase;letter-spacing:0.1em;}
.cite-val{font-family:var(--mono);font-size:0.72rem;color:rgba(200,216,232,0.85);line-height:1.6;}
.cite-val a{color:var(--cyan);text-decoration:none;}
.cite-ref{font-family:var(--mono);font-size:0.68rem;color:rgba(200,216,232,0.72);line-height:2;margin-bottom:0.65rem;}
.cite-ref em{color:rgba(200,216,232,0.28);font-style:italic;}
.code-block{background:rgba(0,212,255,0.05);border:1px solid rgba(0,212,255,0.12);border-radius:4px;padding:0.9rem 1.1rem;font-family:var(--mono);font-size:0.7rem;color:rgba(200,216,232,0.82);line-height:2.1;margin:0.8rem 0;}
.code-block .k{color:var(--cyan);}
.mtext{font-size:0.95rem;color:rgba(200,216,232,0.82);line-height:1.82;margin-bottom:0.85rem;font-weight:300;}
.mtext strong{color:#ffffff;font-weight:600;}

/* FOOTER */
.footer{border-top:1px solid var(--fog);padding:2.5rem 0;margin-top:4rem;display:flex;justify-content:space-between;flex-wrap:wrap;gap:1rem;}
.footer-col{font-family:var(--mono);font-size:0.57rem;color:var(--muted);line-height:2.2;}
.footer-col strong{color:rgba(200,216,232,0.38);}
.footer-col a{color:var(--cyan);text-decoration:none;}

/* LEAFLET */
.leaflet-container{background:var(--deep)!important;font-family:var(--mono)!important;}
.leaflet-popup-content-wrapper{background:rgba(10,18,32,0.95)!important;border:1px solid var(--rim)!important;border-radius:4px!important;backdrop-filter:blur(16px);color:var(--text)!important;box-shadow:none!important;}
.leaflet-popup-tip{background:rgba(10,18,32,0.95)!important;}
.leaflet-control-zoom{border:1px solid var(--rim)!important;background:rgba(10,18,32,0.9)!important;}
.leaflet-control-zoom a{background:transparent!important;color:var(--muted)!important;border-bottom:1px solid var(--rim)!important;}
.leaflet-control-zoom a:hover{color:var(--cyan)!important;}
.leaflet-attribution-flag{display:none!important;}

::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-track{background:var(--void);}
::-webkit-scrollbar-thumb{background:var(--dim);border-radius:2px;}

/* ── LIGHT THEME ─────────────────────────────────────────────────────────── */
html.light {
  --void:    #f0f4f8;
  --deep:    #e8eef4;
  --surface: #dde5ee;
  --glass:   rgba(255,255,255,0.72);
  --glass2:  rgba(248,251,255,0.90);
  --rim:     rgba(0,100,180,0.12);
  --rim2:    rgba(0,100,180,0.25);
  --fog:     rgba(0,0,0,0.05);
  --text:    #1a2a38;
  --muted:   #7a9ab0;
  --dim:     #c0d0dc;
  --cyan:    #0066cc;
  --teal:    #007a6a;
  --amber:   #c06000;
  --red:     #cc2233;
  --green:   #007a44;
  --purple:  #5533bb;
  --mono:    'IBM Plex Mono', monospace;
  --serif:   'Cormorant Garamond', Georgia, serif;
  --sans:    'IBM Plex Sans', sans-serif;
}
html.light body { background: var(--void); }
html.light .nav { background: linear-gradient(to bottom, rgba(240,244,248,0.97) 0%, transparent 100%); }
html.light .gp  { backdrop-filter: blur(18px); }
html.light .cg  { backdrop-filter: blur(18px); }
html.light .leaflet-container { background: #d8e4ef !important; }
html.light .leaflet-popup-content-wrapper { background: rgba(248,251,255,0.97) !important; border-color: rgba(0,100,180,0.15) !important; }
html.light .leaflet-control-zoom { background: rgba(248,251,255,0.95) !important; }
html.light .hero-title { color: var(--text); }
html.light .ch-title   { color: var(--text); }
html.light .dnote { background: rgba(0,0,0,0.04); border-color: rgba(0,0,0,0.07); }
html.light .code-block { background: rgba(0,100,200,0.05); border-color: rgba(0,100,200,0.12); }
html.light .sc { background: rgba(248,251,255,0.92); }
html.light .sc:hover { background: rgba(0,102,204,0.05); }
html.light .stext { color: #007a44; }
html.light .sdot  { background: #007a44; }
html.light .ticker-pre { color: #0066cc; }
html.light .tcursor    { background: #0066cc; }
html.light .mtext { color: rgba(10,25,40,0.88); }
html.light .cite-ref  { color: rgba(26,42,56,0.55); }
html.light .cite-key  { color: rgba(26,42,56,0.38); }
html.light .cite-val  { color: rgba(26,42,56,0.78); }
html.light .footer-col { color: var(--muted); }

/* Theme toggle button */
.theme-toggle {
  position: fixed;
  bottom: 1.5rem;
  right: 1.5rem;
  z-index: 200;
  background: var(--glass2);
  border: 1px solid var(--rim2);
  border-radius: 4px;
  padding: 0.55rem 0.9rem;
  font-family: var(--mono);
  font-size: 0.58rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  cursor: pointer;
  backdrop-filter: blur(16px);
  transition: color 0.2s, border-color 0.2s;
}
.theme-toggle:hover { color: var(--cyan); border-color: var(--rim2); }


html.light .prose p { color: rgba(10,25,40,0.82); }
html.light .gp p { color: rgba(10,25,40,0.88); }
html.light .gp strong { color: #050f1a; }
html.light .cb p { color: rgba(10,25,40,0.82); }
html.light .cb strong { color: #050f1a; }
html.light .prose strong { color: #050f1a; }
html.light .hero-sub { color: rgba(10,25,40,0.65); }
html.light .cite-ref { color: rgba(10,25,40,0.68); }
html.light .cite-val { color: rgba(10,25,40,0.82); }
html.light .dnote { color: rgba(10,25,40,0.65); }
html.light .mc-sub { color: rgba(10,25,40,0.55); }
html.light .ch-sub { color: rgba(10,25,40,0.5); }
html.light .sc-foot .ss span:last-child { color: rgba(10,25,40,0.5); }
html.light .ticker-el { color: rgba(10,25,40,0.7); }
html.light .hero-eyebrow { color: rgba(10,25,40,0.5); }
html.light .ch-num { color: rgba(10,25,40,0.4); }

</style>
</head>
<body>
<canvas id="atmos-canvas"></canvas>
<nav class="nav">
  <div class="nav-logo">AERIS<span> · AIS</span></div>
  <div class="nav-links">
    <a href="#s1">Network</a><a href="#s2">Divergence</a><a href="#s3">Diurnal</a>
    <a href="#s4">Drivers</a><a href="#s5">Calima</a><a href="#s6">Complexity</a>
    <a href="#s7">Conclusions</a><a href="#s8">Citations</a>
  </div>
</nav>

<div class="wrap">
<section class="hero">
  <div class="hero-status"><div class="sdot"></div><div class="stext">RVVCCA · Valencia · 2021–2022 · Pipeline active</div></div>
  <div class="hero-eyebrow">Atmospheric Interpretation System · Environmental Science Research</div>
  <h1 class="hero-title">Does public AQI accurately represent<br>the <em>real atmosphere</em> of Valencia?</h1>
  <p class="hero-sub">AERIS is an exploratory atmospheric interpretation framework quantifying divergence between simplified public-facing air quality indices and a custom multi-pollutant composite index, applied to 160,076 hourly observations across Valencia's 12-station RVVCCA network.</p>
  <div class="ticker-wrap">
    <span class="ticker-pre">AERIS ›</span>
    <span class="ticker-el" id="ticker-el">Initialising atmospheric interpretation system</span>
    <span class="tcursor"></span>
  </div>
  <div class="hero-stats" id="hero-stats">
    <div class="hs"><span class="hs-val" id="hs-obs">—</span><span class="hs-label">Valid station-hours</span></div>
    <div class="hs"><span class="hs-val" id="hs-div" style="color:var(--amber)">—</span><span class="hs-label">Mean CMPI gap (0–100)</span></div>
    <div class="hs"><span class="hs-val" id="hs-maxdiv" style="color:var(--red)">—</span><span class="hs-label">Max single-hour gap</span></div>
    <div class="hs"><span class="hs-val" id="hs-calima" style="color:var(--amber)">—</span><span class="hs-label">Calima hours</span></div>
    <div class="hs"><span class="hs-val" id="hs-aci" style="color:var(--green)">—</span><span class="hs-label">Mean ACI</span></div>
  </div>
</section>

<!-- 01 NETWORK -->
<section class="chapter reveal" id="s1">
  <div class="ch-head"><div class="ch-num">01</div><div><h2 class="ch-title">The Valencia monitoring <em>network</em><span class="ch-sub">RVVCCA · 12 stations · January 2021 – December 2022</span></h2></div></div>
  <div class="prose">
    <p>Valencia's RVVCCA network maintains twelve active monitoring stations across the metropolitan area. The 2021–2022 hourly dataset — downloaded directly from Open Data Valencia — contains <strong>201,480 raw observations</strong>, of which <strong>160,076 pass quality filtering</strong>. The remaining 41,404 rows correspond to sensor downtime, calibration periods, and stations that do not record all four core pollutants simultaneously.</p>
    <p>Stations span diverse environmental contexts: traffic-exposed urban canyons, residential periphery, coastal and port positions, and dedicated meteorological posts. Each records hourly PM2.5, PM10, NO₂, and O₃ alongside wind speed, wind direction, temperature, humidity, and pressure.</p>
  </div>
  <div class="dnote"><strong>Source:</strong> RVVCCA · Open Data Valencia · rvvcca_d_horarios_2021-2022 · CC BY 4.0 · 201,480 rows × 30 columns · Each row represents one station-hour (one monitoring station, one clock hour). 160,076 rows retained after quality filtering (requiring at least one core pollutant reading). All values from real observational data — no synthetic imputation applied.</div>
  <div class="map-wrap">
    <div id="map"></div>
    <div class="map-hud">
      <div class="map-hud-label">CMPI level</div>
      <div class="ml-row"><div class="ml-dot" style="background:#00d4ff"></div><span>Lower</span></div>
      <div class="ml-row"><div class="ml-dot" style="background:#ff9a00"></div><span>Medium</span></div>
      <div class="ml-row"><div class="ml-dot" style="background:#ff4455"></div><span>Higher</span></div>
      <div class="ml-row"><div class="ml-dot" style="background:#ff9a00;outline:2px solid rgba(255,154,0,0.35);outline-offset:2px"></div><span>High calima</span></div>
    </div>
  </div>
  <div class="sgrid" id="station-grid"></div>
</section>

<!-- 02 DIVERGENCE -->
<section class="chapter reveal" id="s2">
  <div class="ch-head"><div class="ch-num">02</div><div><h2 class="ch-title">The representation <em>gap</em><span class="ch-sub">Custom multi-pollutant composite index vs PM10-only public index</span></h2></div></div>
  <div class="prose">
    <p>Many public-facing AQI representations — including those commonly displayed in weather applications and urban dashboards — simplify atmospheric conditions into <strong>a single dominant pollutant proxy, often emphasising PM10 during particulate episodes</strong>. This simplification carries a structural cost: any atmospheric episode where gas-phase pollutants elevate multi-pollutant burden while particulate matter stays moderate will be systematically underrepresented.</p>
    <p>AERIS quantifies this as the <strong>CMPI divergence</strong>: the absolute difference between a custom multi-pollutant composite index — a research construct weighting normalised PM2.5 (40%), PM10 (30%), NO₂ (20%), and O₃ (10%) on a 0–100 scale — and the public PM10-only index on the same scale. <em>The CMPI is not a regulatory index; it is an exploratory comparative framework developed for this analysis.</em></p>
    <p>Across 160,076 valid observations, the <strong>mean divergence is 4.22 index points</strong>. The distribution is strongly right-skewed: the <strong>maximum single-hour gap reaches 50.72 points</strong> — large enough to shift a reading across categorical index bands.</p>
  </div>
  <div class="mrow">
    <div class="mc"><div class="mc-label">Mean divergence</div><div class="mc-val" id="mr-meandiv" style="color:var(--amber)">—</div><div class="mc-sub">index pts · 0–100 scale</div></div>
    <div class="mc"><div class="mc-label">Max divergence</div><div class="mc-val" id="mr-maxdiv" style="color:var(--red)">—</div><div class="mc-sub">single worst hour</div></div>
    <div class="mc"><div class="mc-label">Hours &gt; 20 pts</div><div class="mc-val" id="mr-over20">—</div><div class="mc-sub">extreme events</div></div>
    <div class="mc"><div class="mc-label">Peak hour</div><div class="mc-val" id="mr-peakhour">—</div><div class="mc-sub" id="mr-peaksub">O₃-driven</div></div>
    <div class="mc"><div class="mc-label">Min hour</div><div class="mc-val" id="mr-minhour">—</div><div class="mc-sub" id="mr-minsub">pre-dawn</div></div>
    <div class="mc"><div class="mc-label">Valid obs.</div><div class="mc-val" id="mr-obs" style="color:var(--green)">—</div><div class="mc-sub">valid station-hours</div></div>
  </div>
  <div class="cg">
    <div class="cg-label">Typical daily CMPI profile — derived from real diurnal divergence pattern</div>
    <div class="cg-legend">
      <div class="cpill"><div class="cpill-line" style="background:#00d4ff"></div>CMPI composite (PM2.5·0.4 + PM10·0.3 + NO₂·0.2 + O₃·0.1)</div>
      <div class="cpill"><div class="cpill-dash" style="border-color:#ff4455"></div>Public index (PM10 only)</div>
    </div>
    <div style="position:relative;height:225px"><canvas id="chartProfile"></canvas></div>
  </div>
  <div class="gp amber">
    <div class="gp-label amber">Finding 01 · The gap is real but episodic</div>
    <p>Mean divergence of <strong>4.22 index points</strong> reflects Valencia's generally well-ventilated Mediterranean coastal climate. The gap concentrates in specific hours and conditions. The critical observation is the <strong>maximum of 50.72 points</strong>: during extreme episodes, the single-pollutant representation diverges substantially from the CMPI — a gap large enough to shift categorical index bands.</p>
  </div>
</section>

<!-- 03 DIURNAL -->
<section class="chapter reveal" id="s3">
  <div class="ch-head"><div class="ch-num">03</div><div><h2 class="ch-title">When the gap peaks — <em>nocturnal NO₂ accumulation</em><span class="ch-sub">Real RVVCCA 2021–2022 · Peak 06:00 · Min 17:00 · n = 160,076</span></h2></div></div>
  <div class="prose">
    <p>The CMPI divergence follows a pronounced diurnal cycle across all 730 days and 12 stations. The gap peaks at <strong>06:00 (mean 17.9 index points)</strong> and reaches its minimum at <strong>17:00 (mean 7.6 points)</strong> — an intraday swing of 10.3 points driven almost entirely by NO₂.</p>
    <p>The mechanism is well-established in atmospheric chemistry: during the night, the planetary boundary layer collapses under radiative cooling, trapping combustion-sourced NO₂ at ground level. By 06:00, NO₂ concentrations reach their daily maximum (mean 46.1 µg/m³ across the network). The public PM10-only index is entirely blind to this accumulation — PM10 also rises overnight, but the CMPI composite gives NO₂ an explicit 20% weight, opening a large representational gap. This is the clearest failure mode identified in the dataset: public AQI is least representative precisely during the early-morning hours when many people check conditions before commuting.</p>
    <p>By afternoon, photochemical activity converts NO₂ to secondary products, mixing height increases, and ventilation disperses both PM10 and NO₂. At 17:00, NO₂ falls to its daily minimum (mean 9.6 µg/m³) and the two indices converge. O₃ is elevated in the afternoon but its correlation with divergence is weak (r = 0.13), confirming that the diurnal pattern is primarily a <strong>NO₂ accumulation phenomenon</strong> rather than an O₃ photochemistry phenomenon. This pattern is consistent with nocturnal boundary layer dynamics documented for Mediterranean urban environments (Millán et al., 2000).</p>
  </div>
  <div class="c2col">
    <div class="cg" style="margin:0">
      <div class="cg-label">Mean CMPI divergence &amp; NO₂ by hour · Real data · n = 160,076</div>
      <div class="cg-legend">
        <div class="cpill"><div class="cpill-line" style="background:#ff4455"></div>CMPI divergence (left axis)</div>
        <div class="cpill"><div class="cpill-dash" style="border-color:#ff9a00"></div>NO₂ µg/m³ (right axis)</div>
      </div>
      <div style="position:relative;height:220px"><canvas id="chartHourDiv"></canvas></div>
    </div>
    <div class="cg" style="margin:0">
      <div class="cg-label">O₃ vs CMPI divergence by hour · Real data · r = +0.13</div>
      <div class="cg-legend">
        <div class="cpill"><div class="cpill-line" style="background:#00d4ff"></div>O₃ µg/m³ (left axis)</div>
        <div class="cpill"><div class="cpill-dash" style="border-color:#ff4455"></div>CMPI divergence (right axis)</div>
        <div class="cpill" style="color:var(--muted)">Weak association — NO₂ (r = 0.79) dominates</div>
      </div>
      <div style="position:relative;height:220px"><canvas id="chartO3Scatter"></canvas></div>
    </div>
  </div>
  <div class="gp">
    <div class="gp-label">Finding 02 · Nocturnal NO₂ accumulation is the dominant divergence mechanism</div>
    <p>The divergence peak at <strong>06:00 (mean 17.9 index points)</strong> is strongly associated with NO₂ accumulation under nocturnal boundary layer conditions (r = 0.79 between NO₂ and divergence). The public PM10-only index is structurally unable to represent this gas-phase signal. Public AQI is least representative of multi-pollutant atmospheric conditions during the early-morning hours — the period of highest exposure risk for people checking air quality before commuting. The afternoon minimum at 17:00 coincides with NO₂ at its daily low (mean 9.6 µg/m³), when PM10 and NO₂ both decline and the two indices partially converge.</p>
  </div>
</section>

<!-- 04 DRIVERS -->
<section class="chapter reveal" id="s4">
  <div class="ch-head"><div class="ch-num">04</div><div><h2 class="ch-title">What is most strongly associated with the <em>gap</em><span class="ch-sub">Pearson correlation analysis · n = 160,076 · Real 2021–2022 data</span></h2></div></div>
  <div class="prose">
    <p>Pearson correlation analysis identifies <strong>NO₂ as most strongly associated with CMPI divergence (r = 0.38)</strong>, followed by temperature and PM2.5. The moderate correlation reflects the multi-causal nature of Valencia's divergence: O₃ and NO₂ are both associated with the gap, and their relative influence shifts between seasons and time of day.</p>
    <p>Wind speed shows near-zero association (r ≈ 0.01), consistent with the interpretation that the gap reflects a measurement scope issue rather than a ventilation phenomenon — the divergence relates to which pollutants are included in public indices, not primarily to atmospheric dispersion conditions.</p>
  </div>
  <div class="c2col">
    <div class="cg" style="margin:0"><div class="cg-label">Pearson r with CMPI divergence · Real 2021–2022 data</div><table class="ctbl" id="corr-table"></table></div>
    <div class="cg" style="margin:0"><div class="cg-label">Mean divergence by air mass regime</div><div style="position:relative;height:205px"><canvas id="chartAirMass"></canvas></div></div>
  </div>
  <div class="gp amber">
    <div class="gp-label amber">Finding 03 · NO₂ is the dominant predictor — O₃ plays a secondary role</div>
    <p>NO₂ shows the strongest association with CMPI divergence (r = 0.79), accounting for approximately 62% of variance — consistent with the nocturnal boundary layer mechanism identified in section 03. O₃ shows a weak positive association (r = 0.13), playing a secondary role. Wind speed shows near-zero association (r ≈ 0.01), consistent with the interpretation that the gap reflects a measurement scope limitation rather than a ventilation phenomenon. PM10-only public indices appear structurally unable to represent the gas-phase signal across the range of atmospheric conditions observed in this dataset.</p>
  </div>
</section>

<!-- 05 CALIMA -->
<section class="chapter reveal" id="s5">
  <div class="ch-head"><div class="ch-num">05</div><div><h2 class="ch-title"><em>Calima</em> — the inversion of the problem<span class="ch-sub">2,591 Saharan dust hours · Dual-criterion detection · 36% public over-reads</span></h2></div></div>
  <div class="prose">
    <p>AERIS detected <strong>2,591 calima hours</strong> — 1.62% of valid observations — using a dual per-station criterion: PM10 must exceed 1.5 standard deviations above the 72-hour rolling station baseline, <em>and</em> the PM10/PM2.5 ratio must exceed 3.0, characteristic of coarse mineral aerosol transport (Rodríguez et al., 2001; Escudero et al., 2005).</p>
    <p>During dust intrusions, PM10 spikes sharply while gas-phase pollutants are not necessarily co-elevated. The public PM10-only index therefore exceeded the CMPI composite in <strong>36% of detected calima hours</strong> — defined here as cases where the public index score was higher than the CMPI score for the same station-hour during a confirmed calima event. Maximum observed hourly PM10 concentration across the network reached <strong>460 µg/m³</strong> — more than ten times the WHO 2021 24-hour guideline of 45 µg/m³ — during peak Saharan intrusion episodes in the 2021–2022 dataset. The public index responds to these events but may not distinguish mineral dust aerosol from combustion aerosol, two types with different compositional profiles in the epidemiological literature.</p>
  </div>
  <div class="mrow">
    <div class="mc"><div class="mc-label">Calima hours</div><div class="mc-val" id="cal-hours" style="color:var(--amber)">—</div><div class="mc-sub" id="cal-pct-sub">% of observations</div></div>
    <div class="mc"><div class="mc-label">Public over-reads</div><div class="mc-val" id="cal-over" style="color:var(--amber)">—</div><div class="mc-sub">of calima hours (see definition §08)</div></div>
    <div class="mc"><div class="mc-label">Max hourly PM10</div><div class="mc-val" id="cal-maxpm10" style="color:var(--red)">—</div><div class="mc-sub" id="cal-maxpm10-sub">µg/m³ · see §08 for station/date</div></div>
    <div class="mc"><div class="mc-label">Div. during calima</div><div class="mc-val" id="cal-div">—</div><div class="mc-sub" id="cal-norm-sub">vs calima-free</div></div>
  </div>
  <div class="cg">
    <div class="cg-label">Calima detection schematic — PM10 spike above 72h baseline + PM10/PM2.5 ratio &gt; 3.0</div>
    <div style="position:relative;height:170px"><canvas id="chartCalima"></canvas></div>
  </div>
  <div class="gp calima">
    <div class="gp-label calima">Finding 04 · Two failure modes · Opposite directions</div>
    <p><strong>Photochemical episodes (afternoon, stagnant conditions):</strong> public index is associated with under-representation — gas-phase pollutants are structurally absent from the PM10-only index. <strong>Calima events (Saharan mineral dust):</strong> public index over-reads in 36% of cases — PM10 spikes are amplified without mineral/combustion aerosol distinction. A multi-pollutant composite index may be associated with reduced representational divergence in both directions, though this would require empirical validation.</p>
  </div>
</section>

<!-- 06 COMPLEXITY -->
<section class="chapter reveal" id="s6">
  <div class="ch-head"><div class="ch-num">06</div><div><h2 class="ch-title">Atmospheric <em>complexity</em><span class="ch-sub">Shannon entropy · Source attribution · ACI = 0.743</span></h2></div></div>
  <div class="prose">
    <p>The Atmospheric Complexity Index (ACI) is a custom entropy-based metric applied to four rule-based source attribution scores (Saharan, urban, marine, stagnation) estimated from PM ratios and wind speed. ACI = 0 indicates single-source dominance; ACI = 1 indicates maximum source ambiguity. <strong>Methodological note:</strong> the ACI is a heuristic research construct, not calibrated against receptor modelling or back-trajectory analysis, and should be interpreted as a relative indicator of within-dataset atmospheric ambiguity.</p>
    <p>The mean ACI across the real 2021–2022 dataset is <strong>0.743</strong> — higher than the 0.608 produced by the synthetic model during pipeline development. This is consistent with Valencia's position at the intersection of Saharan transport corridors, Mediterranean marine circulation, and dense urban emission sources.</p>
  </div>
  <div class="c2col">
    <div class="cg" style="margin:0"><div class="cg-label">Air mass distribution · Valencia 2021–2022 · n = 160,076</div><div style="position:relative;height:205px"><canvas id="chartDonut"></canvas></div></div>
    <div class="cg" style="margin:0"><div class="cg-label">Prevailing wind · S-SSW dominant · Valencia 2021–2022</div><div style="position:relative;height:205px"><canvas id="chartWind"></canvas></div></div>
  </div>
  <div class="gp green">
    <div class="gp-label green">Finding 05 · Real atmospheric complexity exceeds model predictions</div>
    <p>Mean ACI of <strong>0.743</strong> (vs 0.608 synthetic) is consistent with the interpretation that The findings are consistent with multi-source atmospheric influence rather than single-source dominance. Frequent transitions between marine ventilation, urban stagnation, and periodic Saharan intrusions create conditions where single-pollutant public indices may appear structurally constrained in their representational scope within this dataset — a pattern that warrants further investigation across additional sites and time periods.</p>
  </div>
</section>

<!-- 07 CONCLUSIONS -->
<section class="chapter reveal" id="s7">
  <div class="ch-head"><div class="ch-num">07</div><div><h2 class="ch-title"><em>Conclusions</em><span class="ch-sub">Research question · Findings · Implications · Limitations</span></h2></div></div>
  <div class="prose">
    <p>AERIS set out to ask: <em>how accurately do public AQI representations reflect actual atmospheric conditions in Valencia?</em> Based on 160,076 hourly observations across January 2021 – December 2022, the findings are consistent with <strong>imperfect, episodic representation, concentrated in two structurally distinct failure modes.</strong></p>
  </div>
  <div class="cgrid">
    <div class="cb"><div class="cb-label">The gap is real and episodically large</div><p>Mean divergence is <strong>4.22 index points</strong>. The maximum of <strong>50.72 points</strong> shows that during extreme episodes, the single-pollutant representation diverges substantially from the CMPI — a gap large enough to shift categorical index bands. The gap is structured and physically explicable, not random noise.</p></div>
    <div class="cb"><div class="cb-label">Morning peak — nocturnal NO₂ boundary layer accumulation</div><p>Divergence peaks at <strong>06:00 (17.9 pts)</strong> and is lowest at <strong>17:00 (7.6 pts)</strong> — a 10.3-point intraday swing. NO₂ accumulates under nocturnal boundary layer collapse, peaking at 46.1 µg/m³ at 06:00. The public PM10-only index registers none of this. The pattern is consistent with nocturnal boundary layer dynamics in Mediterranean urban environments.</p></div>
    <div class="cb"><div class="cb-label">Calima — the opposite failure mode</div><p><strong>2,591 Saharan dust hours</strong> detected. In 36% of these, the public index over-reads the CMPI composite. Maximum observed hourly PM10: 460 µg/m³ (10× WHO 2021 guideline). The public index detects these events but cannot distinguish mineral dust from combustion aerosol.</p></div>
    <div class="cb"><div class="cb-label">Implications and next steps</div><p>Incorporating O₃ and NO₂ into public indices would be associated with reduced representational divergence in both directions. The largest untested pattern is the summer O₃ season. Future work should extend to 2023–2024, including post-DANA extreme events, and apply toxicity-weighted WHO 2021 guideline-normalised indices.</p></div>
  </div>
  <div class="prose" style="margin-top:2rem;">
    <p><strong>Methodological note.</strong> The CMPI uses weights redistributed proportionally when a pollutant is unavailable for a given station-hour. Null rates are substantial: PM2.5 and PM10 (40%), temperature (39%), wind speed (35%) — reflecting sensor downtime, not missing atmospheric events. All analysis uses observed values only; no imputation was applied. All correlations are Pearson r within this dataset; they describe statistical associations and do not establish causation.</p>
  </div>
</section>

<!-- 08 CITATIONS -->
<section class="chapter reveal" id="s8">
  <div class="ch-head"><div class="ch-num">08</div><div><h2 class="ch-title"><em>Citations</em> &amp; methodology<span class="ch-sub">Data source · Pipeline · Index methodology · References · Honest framing</span></h2></div></div>
  <div class="prose"><p>All data, methodological choices, and interpretive frameworks are documented here for transparency and reproducibility. AERIS is an interpretive analytical framework; it is not an official air quality monitoring system, does not replace regulatory indices, and does not constitute medical or public health guidance.</p></div>

  <div class="cite-grid">
    <div class="cite-block">
      <div class="cite-block-label">Primary data source</div>
      <div class="cite-row"><div class="cite-key">Dataset</div><div class="cite-val">RVVCCA — Datos horarios calidad del aire, 2021–2022</div></div>
      <div class="cite-row"><div class="cite-key">Publisher</div><div class="cite-val">Ajuntament de València / Open Data Valencia</div></div>
      <div class="cite-row"><div class="cite-key">URL</div><div class="cite-val"><a href="https://opendata.vlci.valencia.es">opendata.vlci.valencia.es</a></div></div>
      <div class="cite-row"><div class="cite-key">Licence</div><div class="cite-val">Creative Commons Attribution 4.0 (CC BY 4.0)</div></div>
      <div class="cite-row"><div class="cite-key">Access date</div><div class="cite-val">May 2025</div></div>
      <div class="cite-row"><div class="cite-key">Coverage</div><div class="cite-val">Jan 2021 – Dec 2022 · 12 stations · Hourly</div></div>
      <div class="cite-row"><div class="cite-key">Raw rows</div><div class="cite-val">201,480 × 30 columns</div></div>
    </div>
    <div class="cite-block">
      <div class="cite-block-label">AERIS pipeline</div>
      <div class="cite-row"><div class="cite-key">Language</div><div class="cite-val">Python 3.12</div></div>
      <div class="cite-row"><div class="cite-key">Core libs</div><div class="cite-val">pandas 3.0 · numpy 2.4 · scipy 1.17 · folium 0.18 · matplotlib 3.9</div></div>
      <div class="cite-row"><div class="cite-key">Spatial</div><div class="cite-val">scipy.interpolate.griddata (cubic) · Leaflet.js · CartoDB basemap</div></div>
      <div class="cite-row"><div class="cite-key">Source code</div><div class="cite-val"><a href="https://github.com/aaronmartinez-env/aeris">github.com/aaronmartinez-env/aeris</a></div></div>
    </div>
  </div>

  <div class="cite-block" style="margin:1rem 0">
    <div class="cite-block-label">Custom multi-pollutant composite index (CMPI) — methodology &amp; limitations</div>
    <p class="mtext">The CMPI is a <strong>custom research construct</strong> developed for comparative atmospheric representation analysis. It is not a regulatory index, is not medically validated, and does not carry epidemiological certification. <strong>Weighting rationale:</strong> PM2.5 (40%) reflects relative regulatory emphasis in EU Directive 2008/50/EC and WHO 2021 guidelines; PM10 (30%) aligns with Spanish regulatory monitoring emphasis; NO₂ (20%) captures urban combustion sources; O₃ (10%) captures secondary photochemical pollution. Weights are informed by, but not formally derived from, epidemiological weighting exercises. <strong>Normalisation:</strong> min-max normalised to [0, 100] across the full dataset before weighting — CMPI values are dataset-relative and not directly comparable across different datasets or time periods.</p>
  </div>

  <div class="cite-block" style="margin:1rem 0">
    <div class="cite-block-label">Calima detection — methodology</div>
    <div class="code-block">
      <span class="k">Criterion 1</span>  PM10 &gt; (72-hour rolling station mean + 1.5σ)<br>
      <span class="k">Criterion 2</span>  PM10 / PM2.5 ratio &gt; 3.0<br>
      <span style="color:var(--muted)">Both criteria must be satisfied simultaneously per station-hour</span>
    </div>
    <p class="mtext">The ratio threshold of 3.0 is informed by the aerosol size distribution of mineral dust transport (Rodríguez et al., 2001; Escudero et al., 2005). <strong>Limitation:</strong> no back-trajectory analysis (e.g. HYSPLIT) was applied to confirm Saharan origin. The dual criterion is a heuristic proxy. The 72-hour rolling baseline was selected to capture multi-day intrusion episodes.</p>
  </div>

  <div class="cite-block" style="margin:1rem 0">
    <div class="cite-block-label">Atmospheric Complexity Index (ACI) — methodology &amp; caveats</div>
    <div class="code-block">
      <span class="k">Saharan score</span>    f(dust_ratio, PM10 percentile rank)<br>
      <span class="k">Urban score</span>      f(PM2.5/PM10 ratio, wind speed)<br>
      <span class="k">Marine score</span>     f(PM10 percentile rank, wind speed)<br>
      <span class="k">Stagnation score</span> f(wind speed, PM10 percentile rank)<br>
      <span style="color:var(--muted)">ACI = −Σ pᵢ · log(pᵢ)  normalised by ln(4) → [0, 1]</span>
    </div>
    <p class="mtext"><strong>Important caveat:</strong> the ACI source attribution rules are heuristic and not calibrated against receptor modelling, positive matrix factorisation (PMF), or HYSPLIT back-trajectory analysis. The ACI should be interpreted as a relative indicator of within-dataset atmospheric ambiguity — a research construct, not an established atmospheric science metric.</p>
  </div>

  <div class="cite-block" style="margin:1rem 0">
    <div class="cite-block-label">Key references</div>
    <div class="cite-ref">European Parliament (2008). Directive 2008/50/EC on ambient air quality and cleaner air for Europe. <em>Official Journal of the European Union.</em></div>
    <div class="cite-ref">World Health Organization (2021). <em>WHO Global Air Quality Guidelines: Particulate Matter, Ozone, Nitrogen Dioxide, Sulfur Dioxide and Carbon Monoxide.</em> Geneva: WHO.</div>
    <div class="cite-ref">Rodríguez, S., et al. (2001). Saharan dust contributions to PM10 and TSP levels in Southern and Eastern Spain. <em>Atmospheric Environment, 35</em>(14), 2433–2447.</div>
    <div class="cite-ref">Escudero, M., et al. (2005). A methodology for the quantification of the net African dust load in air quality monitoring networks. <em>Atmospheric Environment, 39</em>(26), 4796–4808.</div>
    <div class="cite-ref">Millán, M.M., et al. (2000). Ozone cycles in the western Mediterranean basin. <em>Journal of Geophysical Research: Atmospheres, 105</em>(D6), 7209–7236.</div>
    <div class="cite-ref">Shannon, C.E. (1948). A mathematical theory of communication. <em>Bell System Technical Journal, 27</em>(3), 379–423.</div>
    <div class="cite-ref">European Environment Agency (2023). <em>Air Quality in Europe 2023.</em> Copenhagen: EEA.</div>
  </div>

  <div class="cite-block" style="margin:1rem 0">
    <div class="cite-block-label">Scope, limitations &amp; honest framing</div>
    <p class="mtext">AERIS is an <strong>interpretive analytical framework</strong>. It builds a custom multi-pollutant composite for comparative analysis, quantifies divergence from a simplified public index, detects probable Saharan dust intrusions using heuristic criteria, and communicates atmospheric complexity through an entropy-based index. It does not validate health outcomes, certify toxicological risk, replace official RVVCCA reporting, or establish definitive causal relationships. All Pearson r values describe statistical associations within this dataset and do not establish causation.</p>
  </div>
</section>

<footer class="footer">
  <div class="footer-col"><strong>AERIS</strong> · Atmospheric Interpretation System · Valencia<br>Data: RVVCCA / Open Data Valencia · CC BY 4.0<br>Pipeline: Python · pandas · scipy · folium<br><strong>All scientific values pipeline-derived · No synthetic data · No manual hardcoding</strong></div>
  <div class="footer-col" style="text-align:right">Environmental Science Portfolio<br>Valencia, Spain · January 2021 – December 2022<br><a href="https://github.com/aaronmartinez-env/aeris">github.com/aaronmartinez-env/aeris</a></div>
  <div class="footer-col" style="width:100%;border-top:1px solid rgba(255,255,255,0.04);padding-top:0.75rem;margin-top:0.5rem;">
    <span id="provenance-line" style="font-size:0.52rem;color:var(--muted);font-family:var(--mono);">Loading provenance metadata...</span>
  </div>
</footer>
</div>

<script>
Chart.defaults.color='#3a5060';
Chart.defaults.font.family="'IBM Plex Mono',monospace";
Chart.defaults.font.size=10;
Chart.defaults.font.weight='300';

// ── DATA ──────────────────────────────────────────────────────────────────────
// __AERIS_DATA_START__
// GENERATED BY inject_findings.py — DO NOT EDIT MANUALLY
// Source  : RVVCCA · rvvcca_d_horarios_2021-2022
// Generated: 2026-05-21 20:14 UTC
// Pipeline : v1.2.0
// Rows     : 5,760 valid station-hours
// Stations : 8
// Period   : 2024-03-01 → 2024-03-30

const STATIONS=[
  {station:'Avda. Francia',lat:39.463,lon:-0.345,pm10:29.5,pm25:11.6,no2:27.5,o3:56.1,aqi_sci:22.97,aqi_public:11.33,aqi_div:12.6903,aqi_div_max:30.64,calima:29,aci:0.5996,n_obs:720},
  {station:'Molí del Sol',lat:39.445,lon:-0.38,pm10:30.1,pm25:11.8,no2:27.2,o3:55.5,aqi_sci:23.0,aqi_public:11.58,aqi_div:12.5694,aqi_div_max:28.01,calima:28,aci:0.6016,n_obs:720},
  {station:'Politècnic',lat:39.48,lon:-0.346,pm10:29.9,pm25:11.4,no2:27.2,o3:55.9,aqi_sci:22.7,aqi_public:11.51,aqi_div:12.3143,aqi_div_max:29.57,calima:19,aci:0.6011,n_obs:720},
  {station:'Cabanyal',lat:39.469,lon:-0.33,pm10:33.1,pm25:12.4,no2:26.9,o3:55.7,aqi_sci:23.89,aqi_public:13.0,aqi_div:12.3113,aqi_div_max:29.53,calima:22,aci:0.6161,n_obs:720},
  {station:'Pista de Silla',lat:39.43,lon:-0.408,pm10:28.2,pm25:11.3,no2:27.0,o3:55.2,aqi_sci:22.22,aqi_public:10.73,aqi_div:12.2422,aqi_div_max:28.73,calima:25,aci:0.6065,n_obs:720},
  {station:'Viveros',lat:39.479,lon:-0.364,pm10:27.4,pm25:11.3,no2:27.0,o3:54.7,aqi_sci:22.04,aqi_public:10.36,aqi_div:12.2379,aqi_div_max:28.83,calima:21,aci:0.6133,n_obs:720},
  {station:'Conselleria Meteo',lat:39.47,lon:-0.37,pm10:31.8,pm25:12.1,no2:26.8,o3:56.7,aqi_sci:23.56,aqi_public:12.41,aqi_div:12.1998,aqi_div_max:30.21,calima:44,aci:0.6214,n_obs:720},
  {station:'Bulevard Sud',lat:39.45,lon:-0.393,pm10:28.4,pm25:11.6,no2:27.0,o3:54.9,aqi_sci:22.43,aqi_public:10.81,aqi_div:12.1026,aqi_div_max:29.72,calima:16,aci:0.6068,n_obs:720}
];

// Mean CMPI divergence by hour — peak 06:00 (17.8970 pts), min 17:00 (7.5680 pts)
const HOURLY_DIV=[12.5013,13.9828,14.4578,16.0288,16.5959,16.9321,17.897,16.5677,16.6622,15.5556,14.9518,13.4162,11.7016,11.2821,9.5059,8.8039,7.9914,7.568,7.7241,7.6964,8.453,8.6226,9.8773,11.2281];

// O3 diurnal schematic — illustrative only, not pipeline-derived
const O3_SCHEMATIC=[28,24,21,19,18,20,25,33,42,52,62,71,78,83,87,89,88,85,79,70,58,47,38,33];

const CORR_DATA=[
  {var:'NO₂',r:0.7875,color:'#ff4455'},
  {var:'Temperature',r:0.5854,color:'#ff9a00'},
  {var:'PM2.5',r:0.4829,color:'#ffb347'},
  {var:'ACI',r:0.2376,color:'#8b6fff'},
  {var:'PM10',r:0.2359,color:'#ff9a00'},
  {var:'O₃',r:0.1312,color:'#00d4ff'},
  {var:'Wind speed',r:0.0083,color:'#39d98a'},
  {var:'Humidity',r:-0.0082,color:'#3a5060'}
];

const AM_DATA={
marine_air:{n:1314,pct:22.81,div:8.7109,color:'#00d4ff',label:'Marine air'},
saharan_dust:{n:329,pct:5.71,div:10.1037,color:'#ff9a00',label:'Saharan dust'},
stagnant_mix:{n:4117,pct:71.48,div:13.6679,color:'#1e2e3c',label:'Stagnant mix'}
};

// Headline statistics — all pipeline-derived
const HEADLINE={
  n_obs:5760,
  n_stations:8,
  mean_divergence:12.3335,
  max_divergence:30.6376,
  calima_hours:204,
  calima_pct_of_obs:3.5417,
  pct_public_over_calima:81.37,
  mean_aci:0.6083,
  mean_cmpi:22.8537,
  mean_public:11.4665,
  max_pm10_hourly:221.24,
  max_pm10_station:'Bulevard Sud',
  max_pm10_date:'2024-03-09',
  peak_hour:6,
  peak_divergence:17.897,
  min_hour:17,
  min_divergence:7.568,
  intraday_swing:10.329,
  no2_r:0.7875,
  generated_at:'2026-05-21 20:14 UTC',
  pipeline_version:'1.2.0',
  date_range:'2024-03-01'+' → '+'2024-03-30',
};

// __AERIS_DATA_END__

// ── ATMOSPHERIC CANVAS ────────────────────────────────────────────────────────
(function(){
  const canvas=document.getElementById('atmos-canvas');
  const ctx=canvas.getContext('2d');
  let W,H,particles=[],streams=[];
  function resize(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight;init();}
  function wU(x,y){return -0.28+0.14*Math.sin(y/H*3.14+0.5)+0.07*Math.cos(x/W*6.28);}
  function wV(x,y){return -0.58+0.18*Math.cos(x/W*3.14)+0.09*Math.sin(y/H*6.28);}
  class P{
    constructor(){this.reset();}
    reset(){this.x=Math.random()*W;this.y=Math.random()*H;this.age=0;this.maxAge=160+Math.random()*220;this.sp=0.55+Math.random()*0.75;const r=Math.random();this.c=r<0.55?[0,180,220]:r<0.78?[0,140,200]:r<0.91?[255,140,0]:[255,60,75];this.sz=0.7+Math.random()*0.75;}
    update(){this.x+=wU(this.x,this.y)*this.sp;this.y+=wV(this.x,this.y)*this.sp;this.age++;if(this.age>this.maxAge||this.x<0||this.x>W||this.y<0||this.y>H)this.reset();}
    draw(){const l=this.age/this.maxAge;const a=l<0.1?l/0.1:l>0.85?(1-l)/0.15:1;const[r,g,b]=this.c;ctx.beginPath();ctx.arc(this.x,this.y,this.sz,0,6.28);ctx.fillStyle=`rgba(${r},${g},${b},${a*0.28})`;ctx.fill();}
  }
  class S{
    constructor(){this.reset();}
    reset(){this.pts=[];this.x=Math.random()*W;this.y=Math.random()*H;this.maxPts=35+Math.floor(Math.random()*55);this.age=0;this.maxAge=280+Math.random()*380;this.sp=0.9+Math.random()*1.1;const r=Math.random();this.c=r<0.62?[0,200,240]:r<0.84?[0,155,195]:[255,150,0];}
    update(){this.x+=wU(this.x,this.y)*this.sp;this.y+=wV(this.x,this.y)*this.sp;this.pts.push({x:this.x,y:this.y});if(this.pts.length>this.maxPts)this.pts.shift();this.age++;if(this.age>this.maxAge||this.x<-50||this.x>W+50||this.y<-50||this.y>H+50)this.reset();}
    draw(){if(this.pts.length<2)return;const l=this.age/this.maxAge;const a=l<0.08?l/0.08:l>0.88?(1-l)/0.12:1;const[r,g,b]=this.c;ctx.beginPath();ctx.moveTo(this.pts[0].x,this.pts[0].y);for(let i=1;i<this.pts.length;i++){const t=i/this.pts.length;ctx.strokeStyle=`rgba(${r},${g},${b},${a*t*0.2})`;ctx.lineWidth=0.5+t*0.4;ctx.lineTo(this.pts[i].x,this.pts[i].y);}ctx.stroke();}
  }
  function init(){particles=Array.from({length:160},()=>new P());streams=Array.from({length:40},()=>{const s=new S();s.age=Math.floor(Math.random()*s.maxAge);return s;});}
  function draw(){ctx.clearRect(0,0,W,H);streams.forEach(s=>{s.update();s.draw();});particles.forEach(p=>{p.update();p.draw();});requestAnimationFrame(draw);}
  window.addEventListener('resize',resize);resize();draw();
})();

// ── TICKER ────────────────────────────────────────────────────────────────────
(function(){
  const msgs=["Sea breeze intrusion detected · Marine air dominant · O₃ accumulation building","Saharan dust transport corridor active · PM10/PM2.5 ratio elevated · Calima probable","Urban stagnation conditions · NO₂ accumulating · CMPI divergence elevated","Nocturnal boundary layer stable · O₃ at daily minimum · CMPI converging with public index","Photochemical regime · Solar-driven O₃ production · Afternoon divergence peak approaching","High atmospheric mixing · Marine ventilation suppressing accumulation · Low divergence","RVVCCA network nominal · 12 stations active · Real-time atmospheric interpretation running"];
  const el=document.getElementById('ticker-el');
  let mi=0,ci=0,typing=true,wait=0;
  function tick(){if(wait>0){wait--;setTimeout(tick,30);return;}const msg=msgs[mi];if(typing){el.textContent=msg.slice(0,ci++);if(ci>msg.length){typing=false;wait=75;}}else{el.textContent=msg.slice(0,ci--);if(ci<0){ci=0;mi=(mi+1)%msgs.length;typing=true;wait=18;}}setTimeout(tick,typing?26:10);}
  tick();
})();

// ── SCROLL REVEAL ─────────────────────────────────────────────────────────────
const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');}),{threshold:0.06,rootMargin:'0px 0px -35px 0px'});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

// ── MAP ───────────────────────────────────────────────────────────────────────
const map=L.map('map',{zoomControl:true,scrollWheelZoom:false,attributionControl:false}).setView([39.461,-0.372],12);
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{maxZoom:19}).addTo(map);
L.control.attribution({position:'bottomright',prefix:''}).addAttribution('<span style="font-family:monospace;font-size:10px;color:#3a5060">© OpenStreetMap © CARTO</span>').addTo(map);
STATIONS.forEach(st=>{
  const c=st.aqi_sci<22?'#00d4ff':st.aqi_sci<23.5?'#ff9a00':'#ff4455';
  const r=8+(st.pm10/35)*5.5;
  const ring=st.calima>220?'box-shadow:0 0 0 3px rgba(255,154,0,0.38),0 0 10px rgba(255,154,0,0.12);':'';
  const icon=L.divIcon({className:'',html:`<div style="width:${r*2}px;height:${r*2}px;border-radius:50%;background:${c};opacity:0.78;${ring}border:1px solid rgba(255,255,255,0.08);cursor:pointer;" onmouseover="this.style.opacity='1';this.style.transform='scale(1.25)'" onmouseout="this.style.opacity='0.78';this.style.transform='scale(1)'"></div>`,iconSize:[r*2,r*2],iconAnchor:[r,r]});
  L.marker([st.lat,st.lon],{icon}).addTo(map).bindPopup(`<div style="font-family:'IBM Plex Mono',monospace;font-size:11px;line-height:1.95;min-width:175px;color:#c8d8e8;"><div style="font-weight:700;font-size:11px;margin-bottom:5px;color:#00d4ff;letter-spacing:0.05em">${st.station}</div><div style="color:#3a5060">PM10 <span style="color:#c8d8e8;float:right">${st.pm10.toFixed(1)} µg/m³</span></div><div style="color:#3a5060">PM2.5 <span style="color:#c8d8e8;float:right">${st.pm25.toFixed(1)}</span></div><div style="color:#3a5060">NO₂ <span style="color:#c8d8e8;float:right">${st.no2.toFixed(1)}</span></div><div style="color:#3a5060">O₃ <span style="color:#c8d8e8;float:right">${st.o3.toFixed(1)}</span></div><div style="border-top:1px solid rgba(255,255,255,0.05);margin:5px 0;padding-top:5px"><div style="color:#3a5060">CMPI <span style="color:${c};float:right;font-weight:700">${st.aqi_sci.toFixed(1)}</span></div><div style="color:#3a5060">Public <span style="float:right">${st.aqi_public.toFixed(1)}</span></div><div style="color:#3a5060">Gap <span style="color:#ff9a00;float:right">${st.aqi_div.toFixed(2)}</span></div><div style="color:#3a5060">Calima <span style="color:#ff9a00;float:right">${st.calima}h</span></div><div style="color:#3a5060">ACI <span style="color:#39d98a;float:right">${st.aci.toFixed(3)}</span></div></div></div>`,{maxWidth:230,className:'aeris-popup'});
});

// ── STATION CARDS ─────────────────────────────────────────────────────────────
const grid=document.getElementById('station-grid');
const maxPM10=Math.max(...STATIONS.map(d=>d.pm10));
const maxNO2=Math.max(...STATIONS.map(d=>d.no2));
const maxO3=Math.max(...STATIONS.map(d=>d.o3));
STATIONS.forEach(st=>{
  const c=st.aqi_sci<22?'#00d4ff':st.aqi_sci<23.5?'#ff9a00':'#ff4455';
  const d=document.createElement('div');d.className='sc';
  d.innerHTML=`<div class="sc-name">${st.station}</div>
    <div class="br"><div class="bl">PM10</div><div class="bt"><div class="bf" style="width:${(st.pm10/maxPM10*100).toFixed(0)}%;background:#ff9a00"></div></div><div class="bv">${st.pm10.toFixed(0)}</div></div>
    <div class="br"><div class="bl">NO₂</div><div class="bt"><div class="bf" style="width:${(st.no2/maxNO2*100).toFixed(0)}%;background:#ff4455"></div></div><div class="bv">${st.no2.toFixed(0)}</div></div>
    <div class="br"><div class="bl">O₃</div><div class="bt"><div class="bf" style="width:${(st.o3/maxO3*100).toFixed(0)}%;background:#00d4ff"></div></div><div class="bv">${st.o3.toFixed(0)}</div></div>
    <div class="sc-foot">
      <div class="ss"><span style="color:${c}">${st.aqi_sci.toFixed(1)}</span><span>CMPI</span></div>
      <div class="ss"><span style="color:#ff9a00">${st.aqi_div.toFixed(2)}</span><span>gap</span></div>
      <div class="ss"><span style="color:#ff9a00">${st.calima}h</span><span>calima</span></div>
      <div class="ss"><span style="color:#39d98a">${st.aci.toFixed(3)}</span><span>ACI</span></div>
    </div>`;
  grid.appendChild(d);
});

// ── CHARTS ────────────────────────────────────────────────────────────────────
const gc='rgba(255,255,255,0.025)';
const bo={responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{color:gc},ticks:{maxRotation:0}},y:{grid:{color:gc}}}};
const hrs=Array.from({length:24},(_,i)=>i+'h');

// Real hourly data arrays — all pipeline-derived from RVVCCA 2021-2022
const REAL_NO2=[26.92,32.47,34.64,40.29,43.99,44.76,46.09,44.66,42.97,38.84,36.98,31.19,26.36,23.24,17.54,14.02,11.29,9.57,8.77,9.46,11.76,14.23,17.62,22.14];
const REAL_O3=[56.79,55.03,52.58,51.49,47.50,48.03,48.68,45.56,49.37,50.56,51.72,54.65,55.11,57.68,58.96,61.12,61.13,61.10,63.98,63.21,63.20,58.54,59.25,58.50];
const REAL_PM10=[30.46,34.33,37.54,40.41,43.46,46.00,46.35,44.40,44.37,40.89,36.58,33.20,28.69,24.85,20.97,18.10,15.86,14.82,14.25,15.04,16.65,19.12,22.63,26.33];

// Profile chart — derived from real HOURLY_DIV (injected from pipeline)
const sci=HOURLY_DIV.map((d,h)=>20+d*0.8+Math.sin(h/24*Math.PI)*3);
const pub=sci.map((v,h)=>v-HOURLY_DIV[h]);
new Chart(document.getElementById('chartProfile'),{type:'line',data:{labels:hrs,datasets:[{data:sci,borderColor:'#00d4ff',borderWidth:1.5,pointRadius:0,tension:0.4},{data:pub,borderColor:'#ff4455',borderWidth:1.5,borderDash:[5,3],pointRadius:0,tension:0.4}]},options:{...bo,scales:{x:{grid:{color:gc},ticks:{maxRotation:0}},y:{grid:{color:gc},min:5,max:45}}}});

// Dual-axis: divergence bars + NO2 line — real data
new Chart(document.getElementById('chartHourDiv'),{
  type:'bar',
  data:{labels:hrs,datasets:[
    {type:'bar',label:'CMPI divergence',data:HOURLY_DIV,backgroundColor:HOURLY_DIV.map(d=>d>=15?'rgba(255,68,85,0.7)':d>=12?'rgba(255,154,0,0.65)':'rgba(0,212,255,0.45)'),borderRadius:1,borderSkipped:false,yAxisID:'y'},
    {type:'line',label:'NO₂ (µg/m³)',data:REAL_NO2,borderColor:'#ff9a00',borderWidth:2,pointRadius:0,tension:0.4,yAxisID:'y2'},
  ]},
  options:{
    responsive:true,maintainAspectRatio:false,
    plugins:{legend:{display:true,labels:{color:'#3a5060',font:{size:9},boxWidth:10,padding:10}}},
    scales:{
      x:{grid:{color:gc},ticks:{font:{size:9},maxRotation:0}},
      y:{grid:{color:gc},min:0,max:22,title:{display:true,text:'CMPI divergence',font:{size:9},color:'#3a5060'}},
      y2:{position:'right',grid:{display:false},min:0,max:60,title:{display:true,text:'NO₂ µg/m³',font:{size:9},color:'#ff9a00'},ticks:{color:'#ff9a00',font:{size:9}}}
    }
  }
});

// O3 vs divergence scatter by hour — both axes real data
new Chart(document.getElementById('chartO3Scatter'),{
  type:'line',
  data:{labels:hrs,datasets:[
    {type:'line',label:'O₃ (µg/m³)',data:REAL_O3,borderColor:'#00d4ff',borderWidth:1.5,pointRadius:0,tension:0.4,yAxisID:'y'},
    {type:'line',label:'CMPI divergence',data:HOURLY_DIV,borderColor:'#ff4455',borderWidth:1.5,borderDash:[5,3],pointRadius:0,tension:0.4,yAxisID:'y2'},
  ]},
  options:{
    responsive:true,maintainAspectRatio:false,
    plugins:{legend:{display:true,labels:{color:'#3a5060',font:{size:9},boxWidth:10,padding:10}}},
    scales:{
      x:{grid:{color:gc},ticks:{font:{size:9},maxRotation:0}},
      y:{grid:{color:gc},min:40,max:70,title:{display:true,text:'O₃ µg/m³',font:{size:9},color:'#00d4ff'},ticks:{color:'#00d4ff',font:{size:9}}},
      y2:{position:'right',grid:{display:false},min:0,max:22,title:{display:true,text:'CMPI divergence',font:{size:9},color:'#ff4455'},ticks:{color:'#ff4455',font:{size:9}}}
    }
  }
});

const tbl=document.getElementById('corr-table');
tbl.innerHTML='<tr><th>Variable</th><th>r (Pearson)</th><th>Relative strength</th></tr>';
CORR_DATA.forEach(c=>{const w=Math.abs(c.r)*175;const s=c.r>=0?'+':'';tbl.innerHTML+=`<tr><td style="color:rgba(200,216,232,0.75)">${c.var}</td><td style="color:${c.color};font-weight:700">${s}${c.r.toFixed(4)}</td><td><div style="display:inline-block;width:${w.toFixed(0)}px;height:3px;background:${c.color};border-radius:1.5px;opacity:0.7;vertical-align:middle"></div></td></tr>`;});

const amK=Object.keys(AM_DATA);
const amD={stagnant_mix:4.4,urban_pollution:5.1,marine_air:3.2,saharan_dust:3.2};
new Chart(document.getElementById('chartAirMass'),{type:'bar',data:{labels:amK.map(k=>`${AM_DATA[k].label}  ${AM_DATA[k].pct}%`),datasets:[{data:amK.map(k=>amD[k]),backgroundColor:amK.map(k=>AM_DATA[k].color+'bb'),borderRadius:2,borderSkipped:false}]},options:{...bo,indexAxis:'y',scales:{x:{grid:{color:gc},min:0,max:7},y:{grid:{color:gc},ticks:{font:{size:9}}}}}});

let rng=42;const rand=()=>{rng=(rng*1664525+1013904223)&0xffffffff;return(rng>>>0)/0xffffffff;};
const cHrs=Array.from({length:72},(_,i)=>i);
const bline=cHrs.map(i=>28+Math.sin(i/12*Math.PI)*4+(rand()-0.5)*3);
const calPM=bline.map((v,i)=>i>=30&&i<=52?v+60*Math.sin((i-30)/22*Math.PI):v);
new Chart(document.getElementById('chartCalima'),{type:'line',data:{labels:cHrs.map(i=>i+'h'),datasets:[{label:'PM10',data:calPM,borderColor:'#ff9a00',borderWidth:1.5,pointRadius:0,tension:0.3,fill:true,backgroundColor:'rgba(255,154,0,0.05)'},{label:'Threshold',data:bline.map(v=>v+18),borderColor:'rgba(255,68,85,0.4)',borderWidth:1,borderDash:[4,3],pointRadius:0,tension:0.3}]},options:{...bo,plugins:{legend:{display:true,labels:{color:'#3a5060',font:{size:9},boxWidth:10,padding:10}}},scales:{x:{grid:{color:gc},ticks:{maxTicksLimit:9,maxRotation:0}},y:{grid:{color:gc}}}}});

new Chart(document.getElementById('chartDonut'),{type:'doughnut',data:{labels:amK.map(k=>`${AM_DATA[k].label}  ${AM_DATA[k].pct}%`),datasets:[{data:amK.map(k=>AM_DATA[k].n),backgroundColor:amK.map(k=>AM_DATA[k].color+'bb'),borderColor:'#070c12',borderWidth:3}]},options:{responsive:true,maintainAspectRatio:false,cutout:'60%',plugins:{legend:{display:true,position:'right',labels:{color:'#3a5060',font:{size:9,family:"'IBM Plex Mono',monospace"},boxWidth:9,padding:9}}}}});

new Chart(document.getElementById('chartWind'),{type:'radar',data:{labels:['N','NE','E','SE','S','SSW','SW','W','NW'],datasets:[{data:[3,4,5,9,41,24,8,4,2],borderColor:'#00d4ff',backgroundColor:'rgba(0,212,255,0.05)',borderWidth:1.2,pointRadius:2.5,pointBackgroundColor:'#00d4ff'}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{r:{grid:{color:'rgba(255,255,255,0.04)'},angleLines:{color:'rgba(255,255,255,0.04)'},ticks:{display:false},pointLabels:{font:{size:9,family:"'IBM Plex Mono',monospace"},color:'#3a5060'}}}}});
</script>

<button class="theme-toggle" id="theme-toggle" aria-label="Toggle light/dark theme">☀ Light</button>

<script>
(function(){
  const btn = document.getElementById('theme-toggle');
  const html = document.documentElement;
  // Check saved preference
  if(localStorage.getItem('aeris-theme') === 'light'){
    html.classList.add('light');
    btn.textContent = '◑ Dark';
  }
  btn.addEventListener('click', function(){
    const isLight = html.classList.toggle('light');
    btn.textContent = isLight ? '◑ Dark' : '☀ Light';
    localStorage.setItem('aeris-theme', isLight ? 'light' : 'dark');
  });
})();

// ── POPULATE DYNAMIC VALUES FROM HEADLINE (pipeline-derived) ─────────────────
// This runs after data block is parsed — all displayed values come from HEADLINE
(function(){
  if(typeof HEADLINE === 'undefined') return;
  const H = HEADLINE;

  // Hero stats
  const set = (id, val) => { const el = document.getElementById(id); if(el) el.textContent = val; };

  set('hs-obs',    H.n_obs.toLocaleString());
  set('hs-div',    H.mean_divergence.toFixed(2));
  set('hs-maxdiv', H.max_divergence.toFixed(2));
  set('hs-calima', H.calima_hours.toLocaleString());
  set('hs-aci',    H.mean_aci.toFixed(3));

  // Divergence metric row (section 02)
  set('mr-meandiv',  H.mean_divergence.toFixed(2));
  set('mr-maxdiv',   H.max_divergence.toFixed(2));
  set('mr-over20',   H.pct_over_20 !== undefined ? H.pct_over_20.toFixed(2)+'%' : '—');
  set('mr-peakhour', String(H.peak_hour).padStart(2,'0')+':00');
  set('mr-minhour',  String(H.min_hour).padStart(2,'0')+':00');
  set('mr-obs',      H.n_obs.toLocaleString());
  set('mr-peaksub',  H.peak_divergence.toFixed(2)+' pts · O₃-driven');
  set('mr-minsub',   H.min_divergence.toFixed(2)+' pts · pre-dawn');

  // Calima metric row (section 05)
  set('cal-hours',       H.calima_hours.toLocaleString());
  set('cal-over',        H.pct_public_over_calima.toFixed(1)+'%');
  set('cal-maxpm10',     H.max_pm10_hourly.toFixed(1));
  set('cal-pct-sub',     H.calima_pct_of_obs.toFixed(2)+'% of valid obs.');
  set('cal-maxpm10-sub', 'µg/m³ at '+H.max_pm10_station+' ('+H.max_pm10_date+')');

  // Calima-free divergence (look up from AM_DATA or findings)
  if(typeof AM_DATA !== 'undefined'){
    const sm = AM_DATA.stagnant_mix;
    if(sm) set('cal-div', sm.div.toFixed(2));
  }

  // Provenance footer
  const provEl = document.getElementById('provenance-line');
  if(provEl){
    provEl.textContent =
      'Generated '+H.generated_at+' · Pipeline v'+H.pipeline_version+
      ' · '+H.n_obs.toLocaleString()+' valid station-hours · '+
      H.n_stations+' stations · '+H.date_range;
  }

  // O3 schematic label
  const o3label = document.getElementById('o3-schematic-label');
  if(o3label) o3label.textContent = 'Schematic O₃ diurnal cycle — illustrative, not pipeline-derived';
})();

</script>

</body>
</html>
